# AI Verkenner — environment template. Copy to `.env` and adjust. Never commit `.env`.

# ---- Backend ----
APP_NAME="AI Verkenner API"
APP_VERSION="0.1.0"

# Root-level content directories, resolved by backend/app/core/config.py.
# Paths are relative to the repository root unless absolute.
PROMPTS_DIR="prompts"
SOURCES_FILE="sources/sources.yaml"

# SQLite — the system of record (ADR 0001). Used from M3 onward.
DATABASE_URL="sqlite:///./data/ai_verkenner.db"

# ---- Derived stores (M2 — docker compose) ----
# SQLite is the source of truth; Qdrant + Neo4j are rebuildable derived indices (ADR 0001).
# Defaults target `docker compose up` on the local host. The backend degrades (does not crash)
# when a store is unreachable.
QDRANT_URL="http://localhost:6333"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="verkenner_dev_pw"   # dev-only; change before any non-local use.

# ---- Embeddings + semantic dedup (M3) ----
# EMBEDDER selects the implementation: "sentence-transformers" (real local model; needs the
# 'embeddings' extra: pip install -e ".[embeddings]") or "hashing" (deterministic, no download).
EMBEDDER="sentence-transformers"
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
# Cosine threshold for stage-(b) semantic dedup (higher = stricter; fewer merges).
DEDUP_TAU="0.92"

# ---- Enrichment (M4) ----
# Cloud LLM enriches each new, de-duplicated Event (5 scores + summary/why/action) and extracts
# entities + timestamped relationships. Provider is abstracted: "anthropic" (cloud, needs the
# 'llm' extra + a key), or "none"/"fake" to disable (the run then enriches via the rule-based
# fallback). A missing key also degrades to the fallback — runs never fail on a bad/absent LLM.
LLM_PROVIDER="anthropic"
LLM_MODEL="claude-opus-4-8"
# LLM_API_KEY="sk-ant-..."        # or set ANTHROPIC_API_KEY
MAX_ENTITIES_PER_ITEM="12"
# The user's stack/projects/interests — fed to the LLM so relevance is about *this* user.
# USER_CONTEXT="..."

# ---- Graph write + graph-aware ranking (M5) ----
# The Neo4j graph (NEO4J_* above) is a rebuildable derived index; projection degrades if it's down.
# The ranking signal is layered ON TOP OF the priority class (never changes it; hype still demotes).
# Convergence = distinct sources touching the same entity within this many days (0 = no window).
GRAPH_CONVERGENCE_WINDOW_DAYS="30"
GRAPH_CONVERGENCE_WEIGHT="1.0"
GRAPH_DEGREE_WEIGHT="0.5"
GRAPH_RECENCY_WEIGHT="0.5"
# How strongly the graph signal blends into the (hype-aware) salience tiebreak.
GRAPH_SIGNAL_WEIGHT="1.0"

# CORS origin for the local frontend dev server.
FRONTEND_ORIGIN="http://localhost:5173"

# ---- Frontend ----
# Base URL the frontend uses to reach the backend.
VITE_API_BASE_URL="http://localhost:8000"
