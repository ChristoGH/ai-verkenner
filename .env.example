# AI Verkenner — environment template. Copy to `.env` and adjust. Never commit `.env`.

# ---- Backend ----
APP_NAME="AI Verkenner API"
APP_VERSION="0.1.0"

# Root-level content directories, resolved by backend/app/core/config.py.
# Paths are relative to the repository root unless absolute.
PROMPTS_DIR="prompts"
SOURCES_FILE="sources/sources.yaml"

# Database (placeholder — not used in Task 001; SQLite arrives in Task 004).
DATABASE_URL="sqlite:///./data/ai_verkenner.db"

# ---- Derived stores (M2 — docker compose) ----
# SQLite is the source of truth; Qdrant + Neo4j are rebuildable derived indices (ADR 0001).
# Defaults target `docker compose up` on the local host. The backend degrades (does not crash)
# when a store is unreachable.
QDRANT_URL="http://localhost:6333"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="verkenner_dev_pw"   # dev-only; change before any non-local use.

# CORS origin for the local frontend dev server.
FRONTEND_ORIGIN="http://localhost:5173"

# LLM provider (placeholder — not used until Task 005).
# LLM_API_KEY=""
# LLM_MODEL=""

# ---- Frontend ----
# Base URL the frontend uses to reach the backend.
VITE_API_BASE_URL="http://localhost:8000"
